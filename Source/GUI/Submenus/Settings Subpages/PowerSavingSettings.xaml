<UserControl x:Class="ControllerToMouse.Source.GUI.Submenus.Settings_Subpages.PowerSavingSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"  
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
             mc:Ignorable="d"  
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- 1. ScrollViewer wraps all content to enable scrolling if the window is small -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Style="{StaticResource Header1Style}" Margin="0 0 0 20">Device Polling Settings</TextBlock>

            <!-- ============================================== -->
            <!-- GROUP 1: POLLING SPEED -->
            <!-- ============================================== -->
            <Border>
                <StackPanel>
                    <TextBlock Style="{StaticResource Header2Style}" Margin="0 0 0 10">Polling Speed</TextBlock>

                    <!-- Setting: Polling Speed -->
                    <Grid Margin="0 5 0 15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Polling Speed" />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="The default rate of polling when not in sleep or battery saving modes." />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding ElementName=PollingSlider, Path=Value, Converter={StaticResource MsToHz}, StringFormat='Current: {0} hz'}"/>
                        </StackPanel>

                        <!-- Slider Control -->
                        <Slider x:Name="PollingSlider" Grid.Column="1" Minimum="1" Maximum="20" Value="5" Width="150" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ============================================== -->
            <!-- GROUP 2: SLEEP SETTINGS -->
            <!-- ============================================== -->
            <Border>
                <StackPanel>
                    <TextBlock Style="{StaticResource Header2Style}" Margin="0 0 0 10">Sleep Mode</TextBlock>

                    <!-- Setting: Enable Sleep Mode -->
                    <Grid Margin="0 5 0 15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Enable Controller Sleep" />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="Automatically poll inactive controllers at a lower rate." />
                        </StackPanel>

                        <CheckBox Grid.Column="1" VerticalAlignment="Center" x:Name="SleepModeCheckbox"/>
                    </Grid>

                    <!-- Setting: Polling Speed -->
                    <Grid Margin="0 5 0 15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sleep Polling Speed" />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="After a certain period of inactivity, resort to a lower polling rate to conserve energy." />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding ElementName=SleepPollingSlider, Path=Value, Converter={StaticResource MsToHz}, StringFormat='Current: {0} hz'}"/>
                        </StackPanel>

                        <!-- Slider Control -->
                        <Slider x:Name="SleepPollingSlider" Grid.Column="1" Minimum="10" Maximum="40" Value="40" Width="150" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ============================================== -->
            <!-- GROUP 3: BATTERY SAVER SETTINGS -->
            <!-- ============================================== -->
            <Border>
                <StackPanel>
                    <TextBlock Style="{StaticResource Header2Style}" Margin="0 0 0 10">Battery Saver Mode</TextBlock>

                    <!-- Setting: Enable Battery Saver -->
                    <Grid Margin="0 5 0 15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Battery Saver Mode" />
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="Run at a lower poll rate when on low battery or in Battery Saver mode." />
                        </StackPanel>

                        <CheckBox Grid.Column="1" VerticalAlignment="Center" x:Name="BatterySaverCheckbox"/>
                    </Grid>

                    <StackPanel>

                        <!-- Setting: Polling Speed -->
                        <Grid Margin="0 5 0 15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Battery Saver Polling Speed" />
                                <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="The rate of polling in Battery Saving mode." />
                                <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding ElementName=PowerSaverPollingSpeed, Path=Value, Converter={StaticResource MsToHz}, StringFormat='Current: {0} hz'}"/>
                            </StackPanel>

                            <!-- Slider Control -->
                            <Slider x:Name="PowerSaverPollingSpeed" Grid.Column="1" Minimum="20" Maximum="500" Value="100" Width="150" VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>