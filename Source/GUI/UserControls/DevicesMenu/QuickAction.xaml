<UserControl x:Class="ControllerToMouse.Source.GUI.UserControls.QuickAction"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Button Click="OnClick" HorizontalContentAlignment="Stretch" Cursor="Hand" Margin="0,0,0,10">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="MainBorder" 
                            Background="{StaticResource SurfaceBackgroundBrush}" 
                            CornerRadius="8" Padding="15,12" BorderThickness="1">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#3D3D42"/>
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>

            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ActionName" Text="Action Name"
                           Style="{StaticResource TextBlockBaseStyle}"
                           FontSize="15" FontWeight="Bold" Margin="0,0,0,2"/>

                <TextBlock x:Name="ActionDescription" Text="Action Description"
                           Style="{StaticResource SmallTextStyle}"
                           FontSize="11" TextWrapping="Wrap" Opacity="0.7"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>