<Window x:Class="ControllerToMouse.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controller to Mouse" Height="300" Width="500">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Overview" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <Button Content="Begin Polling" Height="40" Click="StartController_Click" Margin="0,0,0,10"/>
            <TabControl>
                <TabItem Name="Beer" Header="Beer">
                    <TextBlock>Testing 123</TextBlock>
                </TabItem>
                <TabItem Name="Weed" Header="Weed">
                    <TextBlock>Testing 456</TextBlock>
                </TabItem>
            </TabControl>
        </StackPanel>
    </Grid>
</Window>
