<Window x:Class="ControllerToMouse.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controller to Mouse" Width="1440" Height="810" 
        MinWidth="640" MinHeight="360" MaxWidth="1920" MaxHeight="1080"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ThreeDBorderWindow"
        Background="White">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="20,0,0,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#AED6F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>


    <DockPanel>

        <!-- Top Menu Bar -->
        <Border Background="#f0f0f0" DockPanel.Dock="Top" BorderBrush="#ccc" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Height="50" VerticalAlignment="Center">
                <Button Content="Devices" Style="{StaticResource NavButtonStyle}" Click="Devices_Click"/>
                <Button Content="Profiles" Style="{StaticResource NavButtonStyle}" Click="Profiles_Click"/>
                <Button Content="Settings" Style="{StaticResource NavButtonStyle}" Click="Settings_Click"/>
            </StackPanel>
        </Border>

        <!-- Main content area -->
        <ContentControl x:Name="MainContent"/>
    </DockPanel>
</Window>