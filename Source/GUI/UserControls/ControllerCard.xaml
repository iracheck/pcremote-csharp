<UserControl x:Class="ControllerToMouse.GUI.UserControls.ControllerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControllerToMouse.GUI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border BorderBrush="#ccc" BorderThickness="1" CornerRadius="1" Padding="10" Margin="5">
            <Grid>
                <StackPanel>
                    <TextBlock FontWeight="Bold" x:Name="ControllerNameText">Controller Name</TextBlock>
                    <TextBlock x:Name="ControllerProfileText">Controller Profile</TextBlock>
                </StackPanel>
            </Grid>
            
        </Border>
    </Grid>
</UserControl>
