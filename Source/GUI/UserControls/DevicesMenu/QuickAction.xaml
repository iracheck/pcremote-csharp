<UserControl x:Class="ControllerToMouse.Source.GUI.UserControls.QuickAction"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="350">

    <Border 
            CornerRadius="6" 
            Padding="10" 
            Margin="0,0,0,10"
            Style="{StaticResource HoverableBorderPanel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" MouseLeftButtonDown="OnClick">

                <TextBlock Style="{StaticResource TextBlockBaseStyle}" Text="Action Name" x:Name="ActionName"
               FontSize="14" FontWeight="SemiBold" Margin="-1,0,0,0" TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="Action Description" x:Name="ActionDescription"
               FontSize="10" Style="{StaticResource SmallTextStyle}"/>

            </StackPanel>

        </Grid>
    </Border>
</UserControl>