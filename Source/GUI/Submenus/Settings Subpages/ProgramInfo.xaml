<UserControl x:Class="ControllerToMouse.Source.GUI.Submenus.Settings_Subpages.ProgramInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ControllerToMouse.Source.GUI.Submenus.Settings_Subpages"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450"
                    Margin="0,20,0,20" TextBlock.FontSize="14">

            <TextBlock HorizontalAlignment="Center" Style="{StaticResource Header1Style}" Text="About PCRemote"/>

            <TextBlock HorizontalAlignment="Center" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,15" 
                       Text="A controller-to-mouse/keyboard input mapper built for Windows."/>

            <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" x:Name="CurrentVersionBox" Text="[VERSION_INFO]"/>
            <TextBlock HorizontalAlignment="Center" Text="[BUILD_DATE]" x:Name="BuildDateBox" Margin="0,0,0,5"/>

            <TextBlock HorizontalAlignment="Center" Text="Developed by Ira Check" Margin="0,0,0,20"/>

            <Separator Margin="0,10,0,10" Width="300"/>

            <TextBlock HorizontalAlignment="Center" Style="{StaticResource SecondaryTextStyle}" Text="PCRemote — MIT License (Non-Commercial Use Only)" Margin="10"/>

            <TextBlock HorizontalAlignment="Center" Margin="0,5,0,0">
                <Hyperlink NavigateUri="https://github.com/iracheck/pcremote-csharp/tree/main?tab=License-1-ov-file" RequestNavigate="Hyperlink_RequestNavigate"> License and Source Code</Hyperlink>
            </TextBlock>

        </StackPanel>
    </Grid>
</UserControl>
