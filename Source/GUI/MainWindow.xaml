<Window x:Class="ControllerToMouse.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controller to Mouse" Width="900" Height="750" 
        MinWidth="640" MinHeight="360" MaxWidth="1920" MaxHeight="1080"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Closed="OnExit"
        AllowsTransparency="True"
        WindowStyle="None">

    <Border Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <Border 
                Grid.Row="0"
                Background="{StaticResource AppBackgroundBrush}"
                BorderBrush="{StaticResource SurfaceBackgroundBrush}"
                BorderThickness="1">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource Header2Style}" Margin="10 0 0 0">
                        <TextBlock.Text>Controller-to-Mouse</TextBlock.Text>
                        <TextBlock.VerticalAlignment>Center</TextBlock.VerticalAlignment>
                    </TextBlock>
                    
                    <TextBlock Style="{StaticResource SecondaryTextStyle}" Margin="2 5 0 0">
                        <TextBlock.Text>v0.2</TextBlock.Text>
                        <TextBlock.VerticalAlignment>Center</TextBlock.VerticalAlignment>
                    </TextBlock>

                    <Rectangle Fill="Transparent"></Rectangle>

                    <Button Content="—" 
                            Width="40" 
                            Height="40" 
                            Style="{StaticResource WindowControlButton}" 
                            Click="MinimizeButton_Click"/>

                    <Button Content="—" 
                            Width="40" 
                            Height="40" 
                            Style="{StaticResource WindowControlButton}" 
                            Click="MinimizeButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>